NODE_ENV=development
PORT=4001
API_PREFIX=/api/v1
MONGODB_URI=mongodb://localhost:27017/connectify
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
# JSON for a Firebase service account with Cloud Messaging access. Do not commit the real value.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative for hosts where multiline JSON is awkward. Set all three values.
FIREBASE_PROJECT_ID=connectify-8d068
FIREBASE_CLIENT_EMAIL=
# Keep escaped newlines (\\n) when entering this in a hosting dashboard.
FIREBASE_PRIVATE_KEY=
# Alternative: absolute path to a Firebase service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
# Comma-separated browser origins allowed to call the API.
# Native Android/iOS requests usually have no Origin header and still work.
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# Cloudflare R2 — S3 API credentials only (AWS SDK / PutObject)
# R2 → Manage R2 API Tokens → Create → Object Read & Write on your bucket.
# Access Key ID is EXACTLY 32 characters. Secret is a long hex-like string.
# Do NOT use Account API Tokens (cfat_…) — they are not accepted by the S3 endpoint.
# Endpoint = account host only (no /bucket):
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
R2_BUCKET=connectify
R2_ACCESS_KEY_ID=32_char_access_key_from_r2_s3_token
R2_SECRET_ACCESS_KEY=secret_from_same_r2_s3_token
# Public URL for browsers (custom domain or r2.dev public bucket URL), trailing slash optional
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# Admin seed (local/staging): copy to .env — do not commit real passwords.
# Run from backend/: npm run seed:admin
# SEED_ADMIN_EMAIL=you@example.com
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=Connectify Admin
# SEED_ADMIN_USERNAME=handle
# Production only: SEED_ADMIN_CONFIRM=yes

# Resend — REQUIRED for real signup verification & password reset emails (no sandbox “testing” sender in code).
# 1) Verify your domain: https://resend.com/domains
# 2) Create an API key, then set both variables (EMAIL_FROM must use an address on that verified domain).
# Without RESEND_API_KEY: production signup/resend returns 503; local dev may return otpCode in JSON + server logs only.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Connectify <noreply@yourdomain.com>

# OpenAI — Whisper speech-to-text for voice notes and call recordings (requires user consent).
# Without OPENAI_API_KEY, transcription is skipped silently.
# OPENAI_API_KEY=wsk_live_ZKqsunbLvodr9Wlo67AxLgTmsTLlBHn4Cv9H2bb--e4
# OPENAI_WHISPER_MODEL=whisper-1
